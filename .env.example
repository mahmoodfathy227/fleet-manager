# Copy to .env.local and fill in values. Restart `npm run dev` after changes.
# For `npm start`: NEXT_PUBLIC_* are baked in at build time — run `npm run build` again after editing .env.local.

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-side / export routes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (emails, internal fetches)
NEXT_PUBLIC_APP_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Optional: Google Maps (schools / vehicle locations)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Firebase callable HTTP base (push / notifications)
NEXT_PUBLIC_FIREBASE_FUNCTIONS_URL=

# Optional: SMTP (notification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: Samsara telematics (also accepts SAMSARA_TOKEN / SAMSARA_BASE_URL as aliases)
SAMSARA_API_TOKEN=
SAMSARA_API_BASE_URL=https://api.samsara.com/v1
